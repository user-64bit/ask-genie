{
  "name": "ask-genie",
  "displayName": "Ask Genie",
  "version": "0.0.1",
  "author": "user-64bit",
  "description": "A floating AI assistant that allows users to ask questions about the current webpage",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "react",
    "vite",
    "create-chrome-ext"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "fmt": "prettier --write '**/*.{tsx,ts,json,css,scss,md}'",
    "test": "vitest run",
    "zip": "npm run build && node src/zip.js"
  },
  "dependencies": {
    "@motionone/dom": "^10.18.0",
    "bs58": "^6.0.0",
    "motion": "^12.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@types/chrome": "^0.0.246",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "@vitejs/plugin-react": "^4.1.0",
    "gulp": "^5.0.0",
    "gulp-zip": "^6.0.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "vite": "^5.4.10",
    "vitest": "^4.1.9"
  }
}